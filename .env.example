# ─── Required ────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# ─── Common ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# Header secret for POST /process (cron / ops). Generate any random string.
PROCESSOR_SECRET=
# How often the inline outbound worker polls Awaiting customers (sec, min 5)
# PROCESSOR_INTERVAL_SECONDS=60
# Set to 1 if a separate cron will call POST /process (skips inline worker)
# DISABLE_INLINE_PROCESSOR=1

# Used by CSV header mapping (set if you want LLM-based column detection;
# otherwise the upload route falls back to a positional/heuristic mapping)
OPENAI_API_KEY=

# ─── Blooio (SMS) ────────────────────────────────────────────────────────────
BLOOIO_BASE_URL=https://backend.blooio.com/v2/api
# Default body when a company forgets to fill in handshake / payload templates.
# Used for both outbound handshake and inbound YES → payload fallbacks so a
# customer never gets dead air.
# PIPER_DEFAULT_SMS_TEMPLATE=Hi [Name], thanks for choosing [Business Name]. Reply YES for more info.

# ─── TCPA opt-out (auto-DNC on STOP / UNSUBSCRIBE / etc.) ────────────────────
# Reply sent after a customer texts STOP. Empty string disables it (the phone
# is still added to Global DNC either way).
# PIPER_OPTOUT_CONFIRMATION=You're unsubscribed and will not receive further messages. Reply START to resubscribe.
# Comma-separated keywords that trigger opt-out (case-insensitive, whole word).
# PIPER_OPTOUT_KEYWORDS=stop,stopall,unsubscribe,end,quit,cancel,remove,optout,opt out,opt-out

# ─── Inbound webhook (Blooio → POST /webhook) ────────────────────────────────
# Production: deploy and set Blooio inbound URL to https://YOUR-DOMAIN/webhook.
# Local dev: tunneling required (Blooio cannot reach localhost). Use ngrok:
#   1. Sign up:   https://dashboard.ngrok.com/signup
#   2. Authtoken: https://dashboard.ngrok.com/get-started/your-authtoken  → NGROK_AUTHTOKEN
#   3. Domain:    https://dashboard.ngrok.com/cloud-edge/domains          → NGROK_DOMAIN
#                 (free tier includes ONE reserved domain — set this so the URL never changes)
#   4. Run `npm run dev:tunnel`
#   5. Paste the printed https URL/webhook into Blooio (only once if NGROK_DOMAIN is set).
# NGROK_AUTHTOKEN=
# NGROK_DOMAIN=
# ENABLE_DEV_TUNNEL=1
# WEBHOOK_PUBLIC_URL=https://your-host       # printed at startup as a reminder
# WEBHOOK_LOG_BODY=1                         # log full inbound body for debugging

# ─── Airtable schema (defaults match the Piper "Universal CSV" base) ─────────
# Override only if your column names differ.
#
# Customer Data:
# AIRTABLE_CUSTOMER_NAME_FIELD=Name
# AIRTABLE_CUSTOMER_PHONE_FIELD=Phone Number
# AIRTABLE_CUSTOMER_CAMPAIGN_FIELD=Campaign Type
# AIRTABLE_CUSTOMER_STATUS_FIELD=Status
# AIRTABLE_CUSTOMER_COMPANY_ID_FIELD=Company ID
# AIRTABLE_CUSTOMER_BATCH_ID_FIELD=Batch ID
# AIRTABLE_CUSTOMER_REWARD_FIELD=Reward
#
# Customer Data behavior:
# AIRTABLE_CUSTOMER_COMPANY_ID_IS_LINK=1     # Company ID is a linked record (recommended)
# AIRTABLE_CUSTOMER_OMIT_BATCH_ID=1          # set if Customer Data has no Batch ID column
# AIRTABLE_CUSTOMER_OMIT_REWARD=1            # set if you do not store a per-row Reward
# AIRTABLE_CUSTOMER_OMIT_CAMPAIGN_ON_CREATE=1
# AIRTABLE_CUSTOMER_OMIT_PROCESSING_LOCK=1   # if no "Processing"/equivalent status option
# AIRTABLE_CUSTOMER_STATUS_AWAITING=Awaiting
# AIRTABLE_CUSTOMER_STATUS_PROCESSING=Processing   # Piper base often uses "Ready"
# AIRTABLE_CUSTOMER_STATUS_SENT=Sent
# AIRTABLE_CUSTOMER_STATUS_FAILED=Failed           # Piper base often uses "Error"
# Optional Campaign Type label overrides (single-select must already exist):
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REVIEW=Review
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_NO_SHOW=No-Show
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_CANCELLATION=Cancellation
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REACTIVATION=Reactivation
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REFERRAL=Referral
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_UPSELL=Upsell
#
# Campaign Logs:
# AIRTABLE_CAMPAIGN_LOG_TABLE=Campaign Logs
# AIRTABLE_CAMPAIGN_LOG_COMPANY_ID_FIELD=Company ID
# AIRTABLE_CAMPAIGN_LOG_PHONE_FIELD=Phone Number
# AIRTABLE_CAMPAIGN_LOG_CAMPAIGN_FIELD=Campaign Type
# AIRTABLE_CAMPAIGN_LOG_STATUS_FIELD=Status
# AIRTABLE_CAMPAIGN_LOG_SNAPSHOT_LINKS_FIELD=Snapshot: Links
# AIRTABLE_CAMPAIGN_LOG_LATEST_REPLY_FIELD=Latest Reply
# AIRTABLE_CAMPAIGN_LOG_REPLIED_AT_FIELD=Replied At
# AIRTABLE_CAMPAIGN_LOG_HANDSHAKE_SENT_AT_FIELD=Handshake Sent At
# AIRTABLE_CAMPAIGN_LOG_TARGET_PAYLOAD_FIELD=Target Payload
# AIRTABLE_CAMPAIGN_LOG_BATCH_ID_FIELD=Batch ID
# AIRTABLE_CAMPAIGN_LOG_COMPANY_ID_IS_LINK=1
# AIRTABLE_CAMPAIGN_LOG_OMIT_BATCH_ID=1
# AIRTABLE_CAMPAIGN_LOG_OMIT_CAMPAIGN=1
# AIRTABLE_CAMPAIGN_LOG_OMIT_TARGET_PAYLOAD=1
# AIRTABLE_OUTBOUND_CAMPAIGN_LOG_STATUS=Handshake Sent
# AIRTABLE_WEBHOOK_CAMPAIGN_LOG_STATUS_REPLIED=Replied
# AIRTABLE_WEBHOOK_CAMPAIGN_LOG_STATUS_PAYLOAD_SENT=Payload Sent
# AIRTABLE_WEBHOOK_CAMPAIGN_LOG_STATUS_OPT_OUT=Failed/Opt-Out
#
# Dashboard stats (Campaign Logs Status labels):
# PIPER_STATS_CAMPAIGN_LOG_SENT=Handshake Sent,Sent,Payload Sent
# PIPER_STATS_CAMPAIGN_LOG_REPLIED=Replied,Payload Sent,Needs Human Review,Completed
# PIPER_STATS_CAMPAIGN_LOG_FAILED=Failed,Failed/Opt-Out
#
# Uploads:
# AIRTABLE_UPLOAD_STATUS_FIELD=Status
# AIRTABLE_UPLOAD_BATCH_ID_FIELD=Batch ID
# AIRTABLE_UPLOAD_COMPANY_LINK_FIELD=Company
# AIRTABLE_UPLOAD_COMPANY_ID_FIELD=Company ID
# AIRTABLE_UPLOAD_REWARD_FIELD=Reward
# AIRTABLE_UPLOAD_OMIT_BATCH_ID=1
# AIRTABLE_UPLOAD_OMIT_COMPANY_ID_TEXT=1     # if Company ID is a formula/lookup
# AIRTABLE_UPLOAD_SKIP_COMPANY_LINK=1
# AIRTABLE_UPLOAD_INITIAL_STATUS=Pending
# AIRTABLE_UPLOAD_STATUS_DONE=Done
# AIRTABLE_UPLOAD_STATUS_FAILED=Failed
# AIRTABLE_SKIP_UPLOAD_ATTACHMENT=1          # don't store CSV bytes on the row
# AIRTABLE_UPLOAD_ATTACHMENTS_FIELD=Attachments
#
# Company Info (only override if needed):
# AIRTABLE_COMPANY_BLOOIO_CREDENTIALS_FIELD=Blooio API Key & Phone
#
# Global DNC:
# AIRTABLE_DNC_PHONE_FIELD=Phone Number
#
# Optional audit table (fields: Company ID, Phone, Direction, Body, Event):
# AIRTABLE_MESSAGE_HISTORY_TABLE=Message History
