AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
OPENAI_API_KEY=
BLOOIO_BASE_URL=https://backend.blooio.com/v2/api
# If Company Info "Review Template" is empty or named differently, set a fallback body (placeholders: [Name], [Business Name], [Review Link], [Booking Link], [Membership Link]):
# PIPER_DEFAULT_SMS_TEMPLATE=Hi [Name], thanks for choosing [Business Name]. Leave a review: [Review Link]
# If your Airtable column is not literally "Review Template":
# AIRTABLE_COMPANY_REVIEW_TEMPLATE_FIELD=Review Template
PORT=3000
PROCESSOR_SECRET=
# How often the inline worker polls for Awaiting customers (seconds, min 5)
# PROCESSOR_INTERVAL_SECONDS=60

# Optional: override for scripts/trigger-processor.js and scripts/simulate-webhook.js
# API_URL=http://127.0.0.1:3000

# Optional: Airtable table name for inbound/outbound message audit (fields: Company ID, Phone, Direction, Body, Event)
# AIRTABLE_MESSAGE_HISTORY_TABLE=Message History

# If Uploads should never use the Company linked field (only Company ID text), set to 1
# AIRTABLE_UPLOAD_SKIP_COMPANY_LINK=1

# Uploads table attachment field name (multiple attachments). Set to skip storing CSV on the row:
# AIRTABLE_SKIP_UPLOAD_ATTACHMENT=1
# AIRTABLE_UPLOAD_ATTACHMENTS_FIELD=Attachments
# If attachment step returns 403: PAT must include data.records:write and this base must be allowed with Write (not Read). Use field name or fld… id for AIRTABLE_UPLOAD_ATTACHMENTS_FIELD.

# If Airtable returns UNKNOWN_FIELD_NAME, field labels in your base differ from Piper defaults.
# Copy exact names from Airtable (field → customize) or use fldXXXXXXXX IDs where supported.
# Uploads table:
# AIRTABLE_UPLOAD_STATUS_FIELD=Status
# AIRTABLE_UPLOAD_BATCH_ID_FIELD=Batch ID
# AIRTABLE_UPLOAD_COMPANY_LINK_FIELD=Company
# AIRTABLE_UPLOAD_COMPANY_ID_FIELD=Company ID
# If "Company ID" on Uploads is a formula/lookup only, skip writing it:
# AIRTABLE_UPLOAD_OMIT_COMPANY_ID_TEXT=1
# Customer Data table:
# AIRTABLE_CUSTOMER_NAME_FIELD=Name
# AIRTABLE_CUSTOMER_PHONE_FIELD=Phone
# AIRTABLE_CUSTOMER_CAMPAIGN_FIELD=Campaign Type
# If upload fails with "Insufficient permissions to create new select option", Customer Data → Campaign Type
# must already list that option in Airtable (PATs cannot add new single-select options), or map to an existing label:
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REVIEW=Review
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_NO_SHOW=No-Show
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_CANCELLATION=Cancellation
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REACTIVATION=Reactivation
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_REFERRAL=Referral
# AIRTABLE_CUSTOMER_CAMPAIGN_OPTION_UPSELL=Upsell
# Or skip writing campaign on create (CSV campaign not stored on the row):
# AIRTABLE_CUSTOMER_OMIT_CAMPAIGN_ON_CREATE=1
# AIRTABLE_CUSTOMER_STATUS_FIELD=Status
# AIRTABLE_CUSTOMER_COMPANY_ID_FIELD=Company ID
# AIRTABLE_CUSTOMER_BATCH_ID_FIELD=Batch ID
# If Customer Data has no batch column:
# AIRTABLE_CUSTOMER_OMIT_BATCH_ID=1
# If Customer Data "Company ID" (or your override) is a linked record field to Company Info:
# AIRTABLE_CUSTOMER_COMPANY_ID_IS_LINK=1
# Campaign Logs — Universal CSV architecture uses combined text "Company ID & Phone":
# AIRTABLE_CAMPAIGN_LOG_USE_COMBINED_COMPANY_PHONE=1
# AIRTABLE_CAMPAIGN_LOG_COMPANY_PHONE_FIELD=Company ID & Phone
# Or if your base uses a linked Company ID + Phone column instead:
# AIRTABLE_CAMPAIGN_LOG_COMPANY_ID_IS_LINK=1
# Phone column defaults to AIRTABLE_CUSTOMER_PHONE_FIELD then "Phone"; override if needed:
# AIRTABLE_CAMPAIGN_LOG_PHONE_FIELD=Phone Number
# If Batch ID on Campaign Logs is a link or unused: AIRTABLE_CAMPAIGN_LOG_OMIT_BATCH_ID=1
# If Campaign Logs has no campaign column or single-select options don't match CSV values: AIRTABLE_CAMPAIGN_LOG_OMIT_CAMPAIGN=1
# If the table name isn't "Campaign Logs": AIRTABLE_CAMPAIGN_LOG_TABLE=Campaign Logs
# Default snapshot field matches Universal CSV doc (override if your base differs):
# AIRTABLE_CAMPAIGN_LOG_SNAPSHOT_LINKS_FIELD=Snapshot: Links
# Long text / multiline: exact SMS body sent (outbound handshake):
# AIRTABLE_CAMPAIGN_LOG_TARGET_PAYLOAD_FIELD=Target Payload
# AIRTABLE_CAMPAIGN_LOG_OMIT_TARGET_PAYLOAD=1
# Company Info — Handshake Matrix / Payload Matrix + combined Blooio field (see PDF):
# AIRTABLE_COMPANY_HANDSHAKE_MATRIX_FIELD=Handshake Matrix
# AIRTABLE_COMPANY_PAYLOAD_MATRIX_FIELD=Payload Matrix
# AIRTABLE_COMPANY_BLOOIO_CREDENTIALS_FIELD=Blooio API Key & Phone
# Campaign Logs Status must match your single-select exactly, e.g. Handshake Sent vs Sent:
# AIRTABLE_OUTBOUND_CAMPAIGN_LOG_STATUS=Handshake Sent
# Inbound webhook updates (match your options):
# AIRTABLE_WEBHOOK_CAMPAIGN_LOG_STATUS_REPLIED=Needs Human Review
# AIRTABLE_WEBHOOK_CAMPAIGN_LOG_STATUS_PAYLOAD_SENT=Completed
# Dashboard stats — comma-separated labels (optional):
# PIPER_STATS_CAMPAIGN_LOG_SENT=Handshake Sent
# PIPER_STATS_CAMPAIGN_LOG_REPLIED=Needs Human Review,Completed
# PIPER_STATS_CAMPAIGN_LOG_FAILED=Failed/Opt-Out
# Customer Data → Status is a single select: add these exact options in Airtable, or override labels:
# AIRTABLE_CUSTOMER_STATUS_AWAITING=Awaiting
# AIRTABLE_CUSTOMER_STATUS_PROCESSING=Processing
# AIRTABLE_CUSTOMER_STATUS_SENT=Sent
# AIRTABLE_CUSTOMER_STATUS_FAILED=Failed
# If you cannot add a "Processing" option, set to 1 (single worker only; tiny duplicate-send risk if a send succeeds but Airtable update fails):
# AIRTABLE_CUSTOMER_OMIT_PROCESSING_LOCK=1
